{
  "expo": {
    "name": "Collegium: A Guilda do Aprendiz",
    "slug": "frontend",
    "scheme": "solen",
    "version": "1.3.4",
    "orientation": "portrait",
    "icon": "./assets/first.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/first.png",
      "resizeMode": "cover",
      "backgroundColor": "#050b14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beninigmal.frontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/first.png",
        "backgroundColor": "#050b14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.beninigmal.frontend"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00f3ff",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "23c40ecd-61b8-4953-b354-8c75167e35d9"
      },
      "router": {}
    }
  }
}
