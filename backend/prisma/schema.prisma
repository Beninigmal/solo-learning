generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  nome          String
  nickname      String?  @unique
  matricula     String   @unique
  password      String
  isFirstAccess Boolean  @default(true)
  role          String   @default("ALUNO") // ADMIN, PROFESSOR, ALUNO
  turno         String?  // MATUTINO, VESPERTINO, NOTURNO (Para os alunos)
  instituicao   String?  // Instituição de ensino
  xp            Int      @default(0)
  level         Int      @default(1)
  
  turmaId   String?
  turma     Turma?   @relation("TurmaAlunos", fields: [turmaId], references: [id])

  turmaDisciplinas TurmaDisciplina[]

  /// Token Expo para envio de push notifications
  expoPushToken String?

  disciplinas DisciplinaProfessor[] // Relacionamento apenas para Professores
  
  raids           RaidParticipant[]
  questDeliveries QuestDelivery[]
  wrongAnswers    WrongAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Turma {
  id              String   @id @default(uuid())
  nome            String   @unique // ex: "3º Ano A"
  ano             String?
  codigoInvocacao String?  @default("1234")
  
  turmaDisciplinas TurmaDisciplina[]

  users       User[]   @relation("TurmaAlunos")
  quests      Quest[]  @relation("TurmaQuests")
}

model Disciplina {
  id          String   @id @default(uuid())
  nome        String   @unique // ex: "Matemática", "Física"
  professores DisciplinaProfessor[]
  quests      Quest[]
  turmaDisciplinas TurmaDisciplina[]
}

model DisciplinaProfessor {
  professorId   String
  disciplinaId  String
  professor     User       @relation(fields: [professorId], references: [id])
  disciplina    Disciplina @relation(fields: [disciplinaId], references: [id])

  @@id([professorId, disciplinaId])
}

model Quest {
  id           String     @id @default(uuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])
  
  enunciado    String
  gabarito     String?
  xp           Int        @default(200)
  nivel        String     @default("FACIL") // FACIL, MEDIO, DIFICIL

  /// Identifica o lote de 3 quests geradas juntas pelo professor
  batchId      String?
  /// Ordem de entrega dentro do lote (1 = fácil, 2 = médio, 3 = difícil)
  ordem        Int        @default(1)

  turmaAlvoId  String?    // Se a quest for específica para uma turma
  turmaAlvo    Turma?     @relation("TurmaQuests", fields: [turmaAlvoId], references: [id])

  status       String     @default("ATIVA") // ATIVA, EXPIRADA

  semana       String?
  tema         String?
  tags         String[]

  /// Data de expiração da Quest (7 dias após criação)
  expiresAt    DateTime?

  /// Janela de entrega legada (mantida para compatibilidade)
  windowEnd    DateTime?

  deliveries   QuestDelivery[]
  wrongAnswers WrongAnswer[]

  createdAt    DateTime   @default(now())
}

/// Rastreia o estado individual de cada entrega de quest para um aluno
model QuestDelivery {
  id          String   @id @default(uuid())
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  /// SCHEDULED → ainda não disparou | DELIVERED → apareceu na tela
  /// WAITING → aluno clicou Aguardar | COMPLETED → respondida | EXPIRED → TTL estourou
  status      String   @default("SCHEDULED")

  scheduledAt  DateTime  // quando deve ser disparada ao aluno
  deliveredAt  DateTime?
  waitingSince DateTime?
  expiresAt    DateTime? // = waitingSince + 40 min (TTL da fila de espera)
  answeredAt   DateTime?
  isCorrect    Boolean?
  erros        Int       @default(0) // Contador de erros para cálculo da maldição 25%

  createdAt   DateTime @default(now())

  @@unique([questId, userId]) // 1 entrega por quest por aluno
}

model Raid {
  id           String            @id @default(uuid())
  codigo       String            @unique // Código para entrar
  xpBonus      Int               @default(500)
  status       String            @default("OPEN") // OPEN, CLEARED, FAILED
  participantes RaidParticipant[]
}

model RaidParticipant {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  raidId    String
  raid      Raid     @relation(fields: [raidId], references: [id])
  acertos   Int      @default(0) // Checkpoint individual
  
  @@unique([userId, raidId])
}

model WrongAnswer {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id])
  tentativas Int      @default(0)
  resolvido Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, questId])
}

model TurmaDisciplina {
  id           String     @id @default(uuid())
  turmaId      String
  professorId  String
  disciplinaId String

  turma        Turma      @relation(fields: [turmaId], references: [id])
  professor    User       @relation(fields: [professorId], references: [id])
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])

  createdAt    DateTime   @default(now())

  @@unique([turmaId, disciplinaId])
}
